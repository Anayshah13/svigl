# Backend
APP_NAME=API
DEBUG=true
BACKEND_PORT=8000

# PostgreSQL (used by docker-compose + backend when DATABASE_URL is unset)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5433

# Auth cookies (local defaults — override in production)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Google OAuth + JWT — set in backend/.env.local (see backend/.env.example)
