# Copy to .env.local (never commit .env.local)
#
# --- Required ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an authorized redirect URI in Google Cloud Console.
# Dev:  http://localhost:8000/auth/google/callback
# Prod: https://<your-railway-host>/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# Frontend origin used for CORS + post-login redirects (no trailing slash).
# Dev:  http://localhost:3000
# Prod: https://<your-vercel-app>.vercel.app
FRONTEND_URL=http://localhost:3000
SESSION_SECRET_KEY=change-me-to-a-long-random-string

# Prefer JWT_SECRET (also accepts legacy JWT_SECRET_KEY).
JWT_SECRET=change-me-to-a-long-random-string
# Prefer minutes (also accepts legacy JWT_EXPIRATION_SECONDS).
JWT_EXPIRE_MINUTES=10080

# Cookie flags — do not hardcode in code; set per environment.
# Dev (localhost):
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# Prod (Vercel frontend + Railway API, cross-site):
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none

# Optional: comma-separated extra CORS origins (in addition to FRONTEND_URL).
# CORS_ORIGINS=http://localhost:3000,https://staging.example.com

# Database: either DATABASE_URL (Railway) OR POSTGRES_* (docker-compose).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
